# API Configuration
API_TITLE=Ghost Voice TTS
API_VERSION=1.0.0
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql://tts_user:tts_password@localhost:5432/ghost_voice_tts
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND_URL=redis://localhost:6379/2

# TTS Configuration
TTS_MODEL=tortoise
TTS_DEVICE=cuda
TTS_BATCH_SIZE=4
TTS_ENABLE_CACHING=True
TTS_CACHE_TTL=3600

# Voice Cloning
VOICE_CLONE_ENABLED=True
SPEAKER_ENCODER_MODEL=resemblyzer
MIN_VOICE_SAMPLE_DURATION=1.0
MAX_VOICE_SAMPLE_DURATION=30.0

# S3/Storage
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=ghost-voice-tts
S3_REGION=us-east-1

# Audio Output
AUDIO_SAMPLE_RATE=22050
AUDIO_FORMAT=wav
MAX_AUDIO_DURATION=300

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Security
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_STREAMING=True
ENABLE_VOICE_CLONING=True
ENABLE_MULTILINGUAL=True

# Monitoring
PROMETHEUS_ENABLED=True
METRICS_PORT=8001
